{% extends 'base.html.twig' %}

{% block title %}Notifications | SkillLink{% endblock %}

{% block body %}

<div class="max-w-7xl mx-auto py-16 space-y-12">

    <!-- ===================================================== -->
    <!-- HERO HEADER -->
    <!-- ===================================================== -->
    <section class="bg-gradient-to-r from-indigo-700 via-purple-700 to-indigo-900 text-white rounded-3xl shadow-2xl p-10 md:p-14 relative overflow-hidden">

        <div class="relative z-10 flex flex-col md:flex-row justify-between items-start md:items-center gap-8">

            <div>

                <span class="inline-block bg-white/20 backdrop-blur-sm px-4 py-2 rounded-full text-sm font-semibold uppercase tracking-wider mb-5">
                    Centre de notifications
                </span>

                <h1 class="text-4xl md:text-5xl font-extrabold mb-4">
                    Vos Notifications 🔔
                </h1>

                <p class="text-lg text-indigo-100 max-w-3xl leading-relaxed">
                    Consultez votre activité,
                    vos candidatures,
                    vos alertes métier
                    et votre historique utilisateur en temps réel.
                </p>

            </div>

            <div class="text-center">

                <div class="text-5xl font-extrabold">
                    {{ unreadCount }}
                </div>

                <div class="text-indigo-200 uppercase text-sm font-semibold tracking-wider mt-2">
                    Non lues
                </div>

            </div>

        </div>

        <div class="absolute bottom-0 right-0 text-[220px] opacity-10 font-black leading-none select-none hidden lg:block">
            Alerts
        </div>

    </section>

    <!-- ===================================================== -->
    <!-- ACTIONS -->
    <!-- ===================================================== -->
    <section class="flex flex-col md:flex-row justify-between items-center gap-4">

        <div>
            <h2 class="text-2xl font-bold text-slate-800">
                Historique des notifications
            </h2>

            <p class="text-slate-500">
                Notifications centralisées via MongoDB NoSQL
            </p>
        </div>

        {% if unreadCount > 0 %}
            <form method="post" action="{{ path('app_notifications_mark_all_read') }}">
                <button type="submit"
                        class="bg-indigo-700 hover:bg-indigo-800 text-white px-6 py-3 rounded-xl font-bold shadow-lg transition">
                    ✔ Tout marquer comme lu
                </button>
            </form>
        {% endif %}

    </section>

    <!-- ===================================================== -->
    <!-- NOTIFICATIONS LIST -->
    <!-- ===================================================== -->
    <section class="space-y-6">

        {% for notification in notifications %}

            <div class="bg-white rounded-3xl shadow-xl border border-slate-100 p-8 hover:shadow-2xl transition duration-300">

                <div class="flex flex-col lg:flex-row justify-between items-start gap-6">

                    <!-- LEFT -->
                    <div class="flex-1">

                        <div class="flex items-center gap-4 mb-4">

                            {% if notification.isRead %}
                                <span class="bg-slate-200 text-slate-700 px-3 py-1 rounded-full text-xs font-bold uppercase">
                                    Lu
                                </span>
                            {% else %}
                                <span class="bg-green-100 text-green-700 px-3 py-1 rounded-full text-xs font-bold uppercase">
                                    Nouveau
                                </span>
                            {% endif %}

                            <span class="text-sm text-slate-400 font-medium">
                                {{ notification.createdAt|date('d/m/Y H:i') }}
                            </span>

                        </div>

                        <h3 class="text-2xl font-extrabold text-slate-800 mb-3">
                            {{ notification.title }}
                        </h3>

                        <p class="text-slate-600 text-lg leading-relaxed mb-4">
                            {{ notification.message }}
                        </p>

                        <div class="flex flex-wrap gap-3">

                            <span class="bg-indigo-100 text-indigo-700 px-4 py-2 rounded-full text-sm font-semibold">
                                {{ notification.type }}
                            </span>

                        </div>

                    </div>

                    <!-- RIGHT -->
                    <div class="flex flex-col gap-3">

                        {% if not notification.isRead %}
                            <form method="post"
                                  action="{{ path('app_notification_read', {'id': notification.id}) }}">
                                <button type="submit"
                                        class="bg-indigo-700 hover:bg-indigo-800 text-white px-5 py-3 rounded-xl font-bold shadow transition">
                                    Marquer comme lu
                                </button>
                            </form>
                        {% endif %}

                    </div>

                </div>

            </div>

        {% else %}

            <div class="bg-white rounded-3xl shadow-xl border border-slate-100 p-16 text-center">

                <div class="text-7xl mb-6">
                    🔕
                </div>

                <h3 class="text-3xl font-bold text-slate-800 mb-4">
                    Aucune notification disponible
                </h3>

                <p class="text-slate-500 text-lg">
                    Vos futures activités,
                    candidatures
                    et événements apparaîtront ici.
                </p>

            </div>

        {% endfor %}

    </section>

    <!-- ===================================================== -->
    <!-- CTA -->
    <!-- ===================================================== -->
    <section class="bg-gradient-to-r from-slate-900 to-indigo-900 text-white rounded-3xl shadow-2xl p-12 text-center">

        <h2 class="text-4xl font-extrabold mb-5">
            Continuez à piloter votre activité
        </h2>

        <p class="text-slate-300 text-lg max-w-3xl mx-auto mb-8">
            SkillLink centralise vos événements,
            votre sécurité,
            vos candidatures
            et vos performances professionnelles.
        </p>

        <div class="flex flex-col sm:flex-row justify-center gap-4">

            <a href="{{ path('app_dashboard') }}"
               class="bg-indigo-600 hover:bg-indigo-700 px-8 py-4 rounded-xl font-bold shadow-lg transition">
                Retour Dashboard
            </a>

            <a href="{{ path('app_settings') }}"
               class="border border-white px-8 py-4 rounded-xl font-bold hover:bg-white hover:text-indigo-900 transition">
                Paramètres
            </a>

        </div>

    </section>

</div>

{% endblock %}