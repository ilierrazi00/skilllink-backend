{% extends 'base.html.twig' %}

{% block title %}Inscription | SkillLink{% endblock %}

{% block body %}

<div class="max-w-7xl mx-auto py-16">

    <div class="grid grid-cols-1 lg:grid-cols-2 bg-white rounded-3xl shadow-2xl overflow-hidden border border-slate-100">

        <!-- ===================================================== -->
        <!-- LEFT PANEL -->
        <!-- ===================================================== -->
        <div class="bg-gradient-to-br from-indigo-700 via-purple-700 to-indigo-900 text-white p-12 md:p-16 flex flex-col justify-center relative">

            <div class="relative z-10">

                <span class="inline-block bg-white/20 backdrop-blur-sm px-4 py-2 rounded-full text-sm font-semibold uppercase tracking-wider mb-6">
                    Recrutement nouvelle génération
                </span>

                <h1 class="text-5xl md:text-6xl font-extrabold leading-tight mb-8">
                    Rejoignez
                    <span class="text-indigo-200">SkillLink 🚀</span>
                </h1>

                <p class="text-xl text-indigo-100 leading-relaxed mb-12">
                    Développez votre carrière,
                    trouvez les meilleures opportunités
                    ou recrutez les talents de demain
                    grâce à une plateforme RH intelligente.
                </p>

                <!-- Features -->
                <div class="space-y-6">

                    <div class="flex items-center gap-4">
                        <span class="text-3xl">🎯</span>
                        <span class="text-lg font-medium">
                            Matching avancé basé sur les compétences
                        </span>
                    </div>

                    <div class="flex items-center gap-4">
                        <span class="text-3xl">🏢</span>
                        <span class="text-lg font-medium">
                            Entreprises & recruteurs connectés
                        </span>
                    </div>

                    <div class="flex items-center gap-4">
                        <span class="text-3xl">📊</span>
                        <span class="text-lg font-medium">
                            Gestion complète du recrutement
                        </span>
                    </div>

                    <div class="flex items-center gap-4">
                        <span class="text-3xl">🔐</span>
                        <span class="text-lg font-medium">
                            Sécurité, RGPD & conformité professionnelle
                        </span>
                    </div>

                </div>

                <!-- Role explanation -->
                <div class="mt-12 bg-white/10 backdrop-blur-md rounded-2xl p-6 border border-white/20">
                    <h3 class="font-bold text-xl mb-4">
                        Profils disponibles
                    </h3>

                    <div class="space-y-3 text-sm text-indigo-100">
                        <p>👤 <strong>Candidat :</strong> développez votre carrière</p>
                        <p>🏢 <strong>Recruteur :</strong> recrutez efficacement</p>
                        <p>⚙️ <strong>Admin :</strong> supervision stratégique</p>
                    </div>
                </div>

            </div>

            <!-- Decorative -->
            <div class="absolute bottom-0 right-0 text-[200px] opacity-10 font-black leading-none select-none hidden lg:block">
                Skill
            </div>

        </div>

        <!-- ===================================================== -->
        <!-- RIGHT PANEL -->
        <!-- ===================================================== -->
        <div class="p-10 md:p-14 flex flex-col justify-center">

            <!-- Header -->
            <div class="text-center mb-10">
                <h2 class="text-4xl font-extrabold text-indigo-700 mb-3">
                    Créer un compte
                </h2>

                <p class="text-slate-600 text-lg">
                    Rejoignez la nouvelle génération du recrutement
                </p>
            </div>

            <!-- Errors -->
            <div class="mb-6">
                {{ form_errors(registrationForm) }}
            </div>

            <!-- FORM -->
            {{ form_start(registrationForm, {
                'attr': {
                    'class': 'space-y-7'
                }
            }) }}

                <!-- EMAIL -->
                <div>
                    {{ form_label(registrationForm.email, null, {
                        'label_attr': {
                            'class': 'block text-sm font-bold text-slate-700 mb-3'
                        }
                    }) }}

                    {{ form_widget(registrationForm.email, {
                        'attr': {
                            'class': 'w-full rounded-xl border border-slate-300 bg-slate-50 px-5 py-4 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition shadow-sm',
                            'placeholder': 'Votre email professionnel'
                        }
                    }) }}
                </div>

                <!-- NOM / PRENOM -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

                    <div>
                        {{ form_label(registrationForm.nom, null, {
                            'label_attr': {
                                'class': 'block text-sm font-bold text-slate-700 mb-3'
                            }
                        }) }}

                        {{ form_widget(registrationForm.nom, {
                            'attr': {
                                'class': 'w-full rounded-xl border border-slate-300 bg-slate-50 px-5 py-4 focus:ring-2 focus:ring-indigo-500',
                                'placeholder': 'Nom'
                            }
                        }) }}
                    </div>

                    <div>
                        {{ form_label(registrationForm.prenom, null, {
                            'label_attr': {
                                'class': 'block text-sm font-bold text-slate-700 mb-3'
                            }
                        }) }}

                        {{ form_widget(registrationForm.prenom, {
                            'attr': {
                                'class': 'w-full rounded-xl border border-slate-300 bg-slate-50 px-5 py-4 focus:ring-2 focus:ring-indigo-500',
                                'placeholder': 'Prénom'
                            }
                        }) }}
                    </div>

                </div>

                <!-- ROLE TYPE -->
                <div>
                    {{ form_label(registrationForm.roleType, null, {
                        'label_attr': {
                            'class': 'block text-sm font-bold text-slate-700 mb-3'
                        }
                    }) }}

                    {{ form_widget(registrationForm.roleType, {
                        'attr': {
                            'class': 'w-full rounded-xl border border-slate-300 bg-slate-50 px-5 py-4 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition shadow-sm'
                        }
                    }) }}

                    <p class="text-xs text-slate-500 mt-2">
                        Sélectionnez votre profil principal sur la plateforme.
                    </p>
                </div>

                <!-- PASSWORD -->
                <div>
                    {{ form_label(registrationForm.plainPassword, null, {
                        'label_attr': {
                            'class': 'block text-sm font-bold text-slate-700 mb-3'
                        }
                    }) }}

                    {{ form_widget(registrationForm.plainPassword, {
                        'attr': {
                            'class': 'w-full rounded-xl border border-slate-300 bg-slate-50 px-5 py-4 focus:ring-2 focus:ring-indigo-500',
                            'placeholder': 'Mot de passe sécurisé'
                        }
                    }) }}

                    <p class="text-xs text-slate-500 mt-2">
                        Utilisez un mot de passe fort :
                        majuscule, chiffre, caractère spécial.
                    </p>
                </div>

                <!-- TERMS -->
                <div class="space-y-4">

                    <!-- CGU -->
                    <div class="flex items-start gap-4 bg-slate-50 rounded-2xl p-4 border border-slate-200">

                        {{ form_widget(registrationForm.agreeTerms, {
                            'attr': {
                                'class': 'h-5 w-5 mt-1 text-indigo-600 rounded'
                            }
                        }) }}

                        <div class="text-sm text-slate-700 leading-relaxed">
                            {{ form_label(registrationForm.agreeTerms, null, {
                                'label_attr': {
                                    'class': 'font-medium'
                                }
                            }) }}
                        </div>

                    </div>

                    <!-- RGPD -->
                    <div class="flex items-start gap-4 bg-slate-50 rounded-2xl p-4 border border-slate-200">

                        {{ form_widget(registrationForm.agreePrivacy, {
                            'attr': {
                                'class': 'h-5 w-5 mt-1 text-indigo-600 rounded'
                            }
                        }) }}

                        <div class="text-sm text-slate-700 leading-relaxed">
                            {{ form_label(registrationForm.agreePrivacy, null, {
                                'label_attr': {
                                    'class': 'font-medium'
                                }
                            }) }}
                        </div>

                    </div>

                </div>

                <!-- SUBMIT -->
                <button type="submit"
                        class="w-full bg-gradient-to-r from-indigo-700 to-purple-700 hover:from-indigo-800 hover:to-purple-800 text-white font-bold py-4 rounded-xl shadow-xl transition duration-300 text-lg hover:scale-[1.02]">
                    🚀 Créer mon compte
                </button>

            {{ form_end(registrationForm) }}

            <!-- Divider -->
            <div class="flex items-center my-8">
                <div class="flex-grow border-t border-slate-200"></div>
                <span class="px-4 text-sm text-slate-400 font-medium">ou</span>
                <div class="flex-grow border-t border-slate-200"></div>
            </div>

            <!-- LOGIN -->
            <div class="text-center text-slate-600">
                Déjà inscrit ?
                <a href="{{ path('app_login') }}"
                   class="text-indigo-700 font-bold hover:underline ml-2">
                    Connectez-vous
                </a>
            </div>

            <!-- Security Notice -->
            <div class="mt-8 text-center text-xs text-slate-400 leading-relaxed">
                Vos données sont protégées via
                chiffrement sécurisé, conformité RGPD,
                contrôle d’accès, audit sécurité
                et bonnes pratiques DevSecOps.
            </div>

        </div>

    </div>

</div>

{% endblock %}