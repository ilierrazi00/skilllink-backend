{{ form_start(form, {
    'attr': {
        'class': 'space-y-8'
    }
}) }}

{# ===================================================== #}
{# RECRUITER / ADMIN FORM                               #}
{# ===================================================== #}
{% if is_granted('ROLE_RECRUITER') or is_granted('ROLE_ADMIN') %}

    <!-- STATUT -->
    <div>
        {{ form_label(form.statut, 'Statut de la candidature', {
            'label_attr': {
                'class': 'block text-sm font-bold text-slate-700 mb-3'
            }
        }) }}

        {{ form_widget(form.statut, {
            'attr': {
                'class': 'w-full bg-slate-50 border border-slate-300 rounded-xl px-5 py-4 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition shadow-sm'
            }
        }) }}

        {{ form_errors(form.statut) }}
    </div>

    <!-- DATE -->
    <div>
        {{ form_label(form.dateCandidature, 'Date de candidature', {
            'label_attr': {
                'class': 'block text-sm font-bold text-slate-700 mb-3'
            }
        }) }}

        {{ form_widget(form.dateCandidature, {
            'attr': {
                'class': 'w-full bg-slate-50 border border-slate-300 rounded-xl px-5 py-4 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition shadow-sm'
            }
        }) }}

        {{ form_errors(form.dateCandidature) }}
    </div>

    <!-- MESSAGE -->
    <div>
        {{ form_label(form.messageMotivation, 'Message de motivation', {
            'label_attr': {
                'class': 'block text-sm font-bold text-slate-700 mb-3'
            }
        }) }}

        {{ form_widget(form.messageMotivation, {
            'attr': {
                'class': 'w-full bg-slate-50 border border-slate-300 rounded-xl px-5 py-4 min-h-[220px] focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition shadow-sm',
                'placeholder': 'Décrivez la motivation du candidat...'
            }
        }) }}

        {{ form_errors(form.messageMotivation) }}
    </div>

    <!-- PROFIL CANDIDAT -->
    <div>
        {{ form_label(form.candidateProfile, 'Profil candidat', {
            'label_attr': {
                'class': 'block text-sm font-bold text-slate-700 mb-3'
            }
        }) }}

        {{ form_widget(form.candidateProfile, {
            'attr': {
                'class': 'w-full bg-slate-50 border border-slate-300 rounded-xl px-5 py-4 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition shadow-sm'
            }
        }) }}

        {{ form_errors(form.candidateProfile) }}
    </div>

    <!-- JOB OFFER -->
    <div>
        {{ form_label(form.jobOffer, 'Offre d’emploi', {
            'label_attr': {
                'class': 'block text-sm font-bold text-slate-700 mb-3'
            }
        }) }}

        {{ form_widget(form.jobOffer, {
            'attr': {
                'class': 'w-full bg-slate-50 border border-slate-300 rounded-xl px-5 py-4 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition shadow-sm'
            }
        }) }}

        {{ form_errors(form.jobOffer) }}
    </div>

{# ===================================================== #}
{# CANDIDATE FORM                                       #}
{# ===================================================== #}
{% elseif is_granted('ROLE_CANDIDATE') %}

    <!-- MESSAGE -->
    <div>
        {{ form_label(form.messageMotivation, 'Votre message de motivation', {
            'label_attr': {
                'class': 'block text-sm font-bold text-slate-700 mb-3'
            }
        }) }}

        {{ form_widget(form.messageMotivation, {
            'attr': {
                'class': 'w-full bg-slate-50 border border-slate-300 rounded-xl px-5 py-4 min-h-[220px] focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition shadow-sm',
                'placeholder': 'Présentez votre motivation, vos compétences et pourquoi vous correspondez à cette offre...'
            }
        }) }}

        {{ form_errors(form.messageMotivation) }}
    </div>

    <!-- PROFIL -->
    <div>
        {{ form_label(form.candidateProfile, 'Mon profil candidat', {
            'label_attr': {
                'class': 'block text-sm font-bold text-slate-700 mb-3'
            }
        }) }}

        {{ form_widget(form.candidateProfile, {
            'attr': {
                'class': 'w-full bg-slate-100 border border-slate-300 rounded-xl px-5 py-4 shadow-sm'
            }
        }) }}

        {{ form_errors(form.candidateProfile) }}
    </div>

    <!-- OFFRE -->
    <div>
        {{ form_label(form.jobOffer, 'Offre d’emploi sélectionnée', {
            'label_attr': {
                'class': 'block text-sm font-bold text-slate-700 mb-3'
            }
        }) }}

        {{ form_widget(form.jobOffer, {
            'attr': {
                'class': 'w-full bg-slate-50 border border-slate-300 rounded-xl px-5 py-4 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition shadow-sm'
            }
        }) }}

        {{ form_errors(form.jobOffer) }}
    </div>

    {# Hidden RH fields #}
    <div class="hidden">
        {{ form_widget(form.statut) }}
        {{ form_widget(form.dateCandidature) }}
    </div>

{% endif %}

<!-- SUBMIT -->
<div class="pt-8">
    <button class="w-full md:w-auto bg-gradient-to-r from-indigo-700 to-purple-700 hover:from-indigo-800 hover:to-purple-800 text-white font-bold px-10 py-4 rounded-xl shadow-xl transition duration-300 text-lg">
        🚀
        {% if is_granted('ROLE_CANDIDATE') and not is_granted('ROLE_RECRUITER') %}
            {{ button_label|default('Soumettre ma candidature') }}
        {% else %}
            {{ button_label|default('Enregistrer la candidature') }}
        {% endif %}
    </button>
</div>

{{ form_end(form) }}