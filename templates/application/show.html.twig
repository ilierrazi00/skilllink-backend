{% extends 'base.html.twig' %}

{% block title %}
    {% if is_granted('ROLE_CANDIDATE') and not is_granted('ROLE_RECRUITER') %}
        Ma Candidature | SkillLink
    {% else %}
        Détail Candidature | SkillLink
    {% endif %}
{% endblock %}

{% block body %}

<div class="max-w-7xl mx-auto space-y-10">

    <!-- HERO -->
    <section class="bg-gradient-to-r from-indigo-700 to-purple-700 text-white rounded-3xl shadow-2xl p-10">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-8">

            <div>

                <span class="inline-block bg-white/20 backdrop-blur-sm px-4 py-2 rounded-full text-sm font-semibold uppercase tracking-wider mb-5">
                    {% if is_granted('ROLE_RECRUITER') or is_granted('ROLE_ADMIN') %}
                        ATS • Analyse recrutement
                    {% else %}
                        Suivi personnel
                    {% endif %}
                </span>

                <h1 class="text-4xl md:text-5xl font-extrabold mb-4">
                    {{ application.candidateProfile.titreProfil }} 📊
                </h1>

                <p class="text-lg text-indigo-100 mb-4">
                    💼 Postule à : {{ application.jobOffer.titre }}
                </p>

                <div class="flex flex-wrap gap-3">

                    <span class="inline-block bg-white/20 backdrop-blur-md px-5 py-2 rounded-full text-sm font-bold border border-white/30">
                        {{ application.statut }}
                    </span>

                    {% if matchScore >= 80 %}
                        <span class="inline-block bg-green-500/20 text-green-100 px-5 py-2 rounded-full text-sm font-bold border border-green-300/30">
                            Excellent matching
                        </span>
                    {% elseif matchScore >= 60 %}
                        <span class="inline-block bg-yellow-500/20 text-yellow-100 px-5 py-2 rounded-full text-sm font-bold border border-yellow-300/30">
                            Bon matching
                        </span>
                    {% else %}
                        <span class="inline-block bg-red-500/20 text-red-100 px-5 py-2 rounded-full text-sm font-bold border border-red-300/30">
                            Matching faible
                        </span>
                    {% endif %}

                </div>

            </div>

            <div class="text-7xl hidden md:block">
                🚀
            </div>

        </div>
    </section>

    <!-- STATS -->
    <section class="grid grid-cols-1 md:grid-cols-4 gap-8">

        <div class="bg-white rounded-3xl shadow-lg p-8 border border-slate-100">
            <h2 class="text-slate-500 text-sm uppercase font-semibold mb-3">
                Date de candidature
            </h2>

            <p class="text-3xl font-extrabold text-indigo-700">
                {{ application.dateCandidature ? application.dateCandidature|date('d/m/Y') : 'Non définie' }}
            </p>
        </div>

        <div class="bg-white rounded-3xl shadow-lg p-8 border border-slate-100">
            <h2 class="text-slate-500 text-sm uppercase font-semibold mb-3">
                Entreprise
            </h2>

            <p class="text-2xl font-extrabold text-purple-700">
                {{ application.jobOffer.company.nomEntreprise }}
            </p>
        </div>

        <div class="bg-white rounded-3xl shadow-lg p-8 border border-slate-100">
            <h2 class="text-slate-500 text-sm uppercase font-semibold mb-3">
                Offre
            </h2>

            <p class="text-xl font-bold text-green-600">
                {{ application.jobOffer.titre }}
            </p>
        </div>

        <div class="bg-white rounded-3xl shadow-lg p-8 border border-slate-100">
            <h2 class="text-slate-500 text-sm uppercase font-semibold mb-3">
                Score de compatibilité
            </h2>

            <p class="text-4xl font-extrabold
                {% if matchScore >= 80 %}
                    text-green-600
                {% elseif matchScore >= 60 %}
                    text-yellow-500
                {% else %}
                    text-red-500
                {% endif %}
            ">
                {{ matchScore }}%
            </p>
        </div>

    </section>

    <!-- MESSAGE -->
    <section class="bg-white rounded-3xl shadow-2xl p-10 border border-slate-100">

        <h2 class="text-3xl font-bold text-slate-800 mb-6">
            Message de motivation
        </h2>

        <div class="bg-slate-50 rounded-2xl p-8 text-slate-700 text-lg leading-relaxed border border-slate-200">
            {{ application.messageMotivation ?: 'Aucun message renseigné.' }}
        </div>

    </section>

    <!-- ANALYSE -->
    <section class="bg-white rounded-3xl shadow-2xl p-10 border border-slate-100">

        <h2 class="text-3xl font-bold text-slate-800 mb-6">
            Analyse intelligente SkillLink
        </h2>

        <div class="bg-slate-50 rounded-2xl p-8 border border-slate-200">

            {% if matchScore >= 80 %}
                <p class="text-green-700 text-xl font-semibold leading-relaxed">
                    ✔ Ce candidat présente une excellente compatibilité avec l’offre.
                    Son profil correspond fortement aux compétences recherchées.
                </p>
            {% elseif matchScore >= 60 %}
                <p class="text-yellow-700 text-xl font-semibold leading-relaxed">
                    ✔ Ce candidat présente une bonne compatibilité.
                    Quelques compétences complémentaires pourraient renforcer sa candidature.
                </p>
            {% else %}
                <p class="text-red-700 text-xl font-semibold leading-relaxed">
                    ✔ Compatibilité limitée détectée.
                    Une montée en compétences ou une offre plus adaptée est recommandée.
                </p>
            {% endif %}

        </div>

    </section>

    <!-- ACTIONS -->
    <section class="bg-white rounded-3xl shadow-lg p-8 border border-slate-100">

        <div class="flex flex-col md:flex-row flex-wrap gap-4 justify-between items-center">

            <div class="flex flex-wrap gap-4">

                {% if is_granted('ROLE_RECRUITER') or is_granted('ROLE_ADMIN') %}
                    <a href="{{ path('app_application_edit', {'id': application.id}) }}"
                       class="bg-gradient-to-r from-indigo-700 to-purple-700 hover:from-indigo-800 hover:to-purple-800 text-white px-8 py-4 rounded-xl shadow-lg font-bold transition">
                        ✏️ Modifier
                    </a>
                {% endif %}

                <a href="{{ path('app_application_index') }}"
                   class="bg-slate-200 hover:bg-slate-300 text-slate-800 px-8 py-4 rounded-xl font-bold transition">
                    ← Retour
                </a>

            </div>

            {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_RECRUITER') %}
                <div>
                    {{ include('application/_delete_form.html.twig') }}
                </div>
            {% endif %}

        </div>

    </section>

</div>

{% endblock %}