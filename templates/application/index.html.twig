{% extends 'base.html.twig' %}

{% block title %}Candidatures | SkillLink{% endblock %}

{% block body %}

<div class="space-y-12">

    {# ===================================================== #}
    {# RECRUITER / ADMIN VIEW                               #}
    {# ===================================================== #}
    {% if is_granted('ROLE_RECRUITER') or is_granted('ROLE_ADMIN') %}

        <!-- HERO HEADER -->
        <section class="bg-gradient-to-r from-indigo-700 via-purple-700 to-indigo-900 text-white rounded-3xl shadow-2xl p-10 md:p-14 relative overflow-hidden">

            <div class="relative z-10 flex flex-col md:flex-row justify-between items-start md:items-center gap-8">

                <div>

                    <span class="inline-block bg-white/20 backdrop-blur-sm px-4 py-2 rounded-full text-sm font-semibold uppercase tracking-wider mb-5">
                        ATS • Workflow recrutement
                    </span>

                    <h1 class="text-4xl md:text-5xl font-extrabold mb-4">
                        Gestion des Candidatures 📊
                    </h1>

                    <p class="text-lg text-indigo-100 max-w-3xl leading-relaxed">
                        Centralisez le suivi des candidatures,
                        structurez vos processus RH,
                        optimisez vos recrutements
                        et améliorez votre performance.
                    </p>

                </div>

                <a href="{{ path('app_application_new') }}"
                   class="bg-white text-indigo-700 px-8 py-4 rounded-xl font-bold shadow-lg hover:bg-indigo-50 hover:scale-105 transition">
                    + Nouvelle Candidature
                </a>

            </div>

            <div class="absolute bottom-0 right-0 text-[220px] opacity-10 font-black leading-none select-none hidden lg:block">
                ATS
            </div>

        </section>

        <!-- KPI -->
        <section class="grid grid-cols-1 md:grid-cols-5 gap-6">

            <div class="bg-white rounded-2xl shadow-lg p-6 border border-slate-100 hover:shadow-xl transition">
                <h2 class="text-slate-500 text-sm uppercase font-semibold mb-2">
                    Total
                </h2>

                <p class="text-3xl font-bold text-indigo-700">
                    {{ applications|length }}
                </p>
            </div>

            <div class="bg-white rounded-2xl shadow-lg p-6 border border-slate-100 hover:shadow-xl transition">
                <h2 class="text-slate-500 text-sm uppercase font-semibold mb-2">
                    En attente
                </h2>

                <p class="text-3xl font-bold text-slate-700">
                    ATS
                </p>
            </div>

            <div class="bg-white rounded-2xl shadow-lg p-6 border border-slate-100 hover:shadow-xl transition">
                <h2 class="text-slate-500 text-sm uppercase font-semibold mb-2">
                    Entretiens
                </h2>

                <p class="text-3xl font-bold text-yellow-600">
                    RH
                </p>
            </div>

            <div class="bg-white rounded-2xl shadow-lg p-6 border border-slate-100 hover:shadow-xl transition">
                <h2 class="text-slate-500 text-sm uppercase font-semibold mb-2">
                    Recrutement
                </h2>

                <p class="text-3xl font-bold text-green-600">
                    Actif
                </p>
            </div>

            <div class="bg-white rounded-2xl shadow-lg p-6 border border-slate-100 hover:shadow-xl transition">
                <h2 class="text-slate-500 text-sm uppercase font-semibold mb-2">
                    Matching
                </h2>

                <p class="text-3xl font-bold text-pink-600">
                    IA
                </p>
            </div>

        </section>

    {% else %}

        {# ===================================================== #}
        {# CANDIDATE VIEW                                      #}
        {# ===================================================== #}

        <!-- HERO -->
        <section class="bg-gradient-to-r from-indigo-700 via-purple-700 to-indigo-900 text-white rounded-3xl shadow-2xl p-10 md:p-14 relative overflow-hidden">

            <div class="relative z-10 flex flex-col md:flex-row justify-between items-start md:items-center gap-8">

                <div>

                    <span class="inline-block bg-white/20 backdrop-blur-sm px-4 py-2 rounded-full text-sm font-semibold uppercase tracking-wider mb-5">
                        Suivi personnel • Candidat
                    </span>

                    <h1 class="text-4xl md:text-5xl font-extrabold mb-4">
                        Mes Candidatures 🚀
                    </h1>

                    <p class="text-lg text-indigo-100 max-w-3xl leading-relaxed">
                        Suivez vos candidatures,
                        consultez vos opportunités,
                        surveillez vos statuts
                        et développez votre carrière.
                    </p>

                </div>

                <a href="{{ path('app_job_offer_index') }}"
                   class="bg-white text-indigo-700 px-8 py-4 rounded-xl font-bold shadow-lg hover:bg-indigo-50 hover:scale-105 transition">
                    Voir les offres
                </a>

            </div>

            <div class="absolute bottom-0 right-0 text-[220px] opacity-10 font-black leading-none select-none hidden lg:block">
                Talent
            </div>

        </section>

        <!-- KPI -->
        <section class="grid grid-cols-1 md:grid-cols-4 gap-6">

            <div class="bg-white rounded-2xl shadow-lg p-6 border border-slate-100">
                <h2 class="text-slate-500 text-sm uppercase font-semibold mb-2">
                    Total
                </h2>

                <p class="text-3xl font-bold text-indigo-700">
                    {{ applications|length }}
                </p>
            </div>

            <div class="bg-white rounded-2xl shadow-lg p-6 border border-slate-100">
                <h2 class="text-slate-500 text-sm uppercase font-semibold mb-2">
                    En cours
                </h2>

                <p class="text-3xl font-bold text-yellow-600">
                    ATS
                </p>
            </div>

            <div class="bg-white rounded-2xl shadow-lg p-6 border border-slate-100">
                <h2 class="text-slate-500 text-sm uppercase font-semibold mb-2">
                    Opportunités
                </h2>

                <p class="text-3xl font-bold text-green-600">
                    RH
                </p>
            </div>

            <div class="bg-white rounded-2xl shadow-lg p-6 border border-slate-100">
                <h2 class="text-slate-500 text-sm uppercase font-semibold mb-2">
                    Matching
                </h2>

                <p class="text-3xl font-bold text-pink-600">
                    IA
                </p>
            </div>

        </section>

    {% endif %}

    <!-- ===================================================== -->
    <!-- APPLICATION DIRECTORY -->
    <!-- ===================================================== -->
    <section class="bg-white rounded-3xl shadow-2xl overflow-hidden border border-slate-100">

        <!-- Header -->
        <div class="flex flex-col md:flex-row justify-between items-center px-8 py-6 border-b border-slate-100 bg-slate-50 gap-4">

            <div>
                <h2 class="text-2xl font-bold text-slate-800">
                    {% if is_granted('ROLE_RECRUITER') or is_granted('ROLE_ADMIN') %}
                        Pipeline des candidatures
                    {% else %}
                        Mes candidatures
                    {% endif %}
                </h2>

                <p class="text-slate-500 text-sm">
                    {% if is_granted('ROLE_RECRUITER') or is_granted('ROLE_ADMIN') %}
                        Vue centralisée du recrutement
                    {% else %}
                        Suivi de vos candidatures personnelles
                    {% endif %}
                </p>
            </div>

            {% if is_granted('ROLE_RECRUITER') or is_granted('ROLE_ADMIN') %}
                <div class="flex gap-3">
                    <a href="{{ path('app_job_offer_index') }}"
                       class="bg-indigo-100 text-indigo-700 px-4 py-2 rounded-lg font-semibold text-sm hover:bg-indigo-200 transition">
                        Offres
                    </a>

                    <a href="{{ path('app_candidate_profile_index') }}"
                       class="bg-purple-100 text-purple-700 px-4 py-2 rounded-lg font-semibold text-sm hover:bg-purple-200 transition">
                        Talents
                    </a>
                </div>
            {% endif %}

        </div>

        <!-- Table -->
        <div class="overflow-x-auto">

            <table class="w-full text-left min-w-[1400px]">

                <thead class="bg-slate-100 text-slate-700 uppercase text-sm tracking-wide">
                    <tr>
                        <th class="px-6 py-5">ID</th>
                        <th class="px-6 py-5">Candidat</th>
                        <th class="px-6 py-5">Offre</th>
                        <th class="px-6 py-5">Entreprise</th>
                        <th class="px-6 py-5">Statut</th>
                        <th class="px-6 py-5">Date</th>
                        <th class="px-6 py-5">Matching</th>
                        <th class="px-6 py-5">Actions</th>
                    </tr>
                </thead>

                <tbody class="divide-y divide-slate-200">

                    {% for application in applications %}
                        <tr class="hover:bg-slate-50 transition">

                            <td class="px-6 py-5 font-semibold text-slate-700">
                                #{{ application.id }}
                            </td>

                            <td class="px-6 py-5">
    <div class="font-bold text-slate-800 text-lg">
        {{ application.candidateProfile?.titreProfil ?? 'Profil non renseigné' }}
    </div>

    <div class="text-sm text-slate-500">
        Talent SkillLink
    </div>
</td>

                            <td class="px-6 py-5">
                                <span class="font-semibold text-purple-700">
                                    {{ application.jobOffer.titre }}
                                </span>
                            </td>

                            <td class="px-6 py-5 text-slate-600">
                                {{ application.jobOffer.company.nomEntreprise }}
                            </td>

                            <td class="px-6 py-5">
                                {% if application.statut == 'Acceptée' %}
                                    <span class="bg-green-100 text-green-700 px-3 py-1 rounded-full text-sm font-bold">
                                        {{ application.statut }}
                                    </span>
                                {% elseif application.statut == 'Refusée' %}
                                    <span class="bg-red-100 text-red-700 px-3 py-1 rounded-full text-sm font-bold">
                                        {{ application.statut }}
                                    </span>
                                {% elseif application.statut == 'Entretien' %}
                                    <span class="bg-yellow-100 text-yellow-700 px-3 py-1 rounded-full text-sm font-bold">
                                        {{ application.statut }}
                                    </span>
                                {% else %}
                                    <span class="bg-slate-100 text-slate-700 px-3 py-1 rounded-full text-sm font-bold">
                                        {{ application.statut }}
                                    </span>
                                {% endif %}
                            </td>

                            <td class="px-6 py-5 text-slate-600">
                                {{ application.dateCandidature ? application.dateCandidature|date('d/m/Y') : 'Non définie' }}
                            </td>

                            <td class="px-6 py-5">
                                <span class="bg-pink-100 text-pink-700 px-3 py-1 rounded-full text-sm font-bold">
                                    Smart
                                </span>
                            </td>

                            <td class="px-6 py-5">
                                <div class="flex flex-wrap gap-3">

                                    <a href="{{ path('app_application_show', {'id': application.id}) }}"
                                       class="bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-lg text-sm font-semibold shadow">
                                        Voir
                                    </a>

                                    {% if is_granted('ROLE_RECRUITER') or is_granted('ROLE_ADMIN') %}
                                        <a href="{{ path('app_application_edit', {'id': application.id}) }}"
                                           class="bg-slate-200 hover:bg-slate-300 text-slate-800 px-4 py-2 rounded-lg text-sm font-semibold shadow">
                                            Modifier
                                        </a>
                                    {% endif %}

                                </div>
                            </td>

                        </tr>

                    {% else %}

                        <tr>
                            <td colspan="8" class="px-6 py-12 text-center text-slate-500 text-lg">
                                Aucune candidature trouvée.
                            </td>
                        </tr>

                    {% endfor %}

                </tbody>

            </table>

        </div>

    </section>

    <!-- CTA -->
    {% if is_granted('ROLE_RECRUITER') or is_granted('ROLE_ADMIN') %}
        <section class="bg-gradient-to-r from-slate-900 to-indigo-900 text-white rounded-3xl shadow-2xl p-12 text-center">

            <h2 class="text-4xl font-extrabold mb-5">
                Optimisez votre pipeline de recrutement
            </h2>

            <p class="text-slate-300 text-lg max-w-3xl mx-auto mb-8">
                Structurez votre ATS,
                améliorez vos recrutements,
                centralisez vos candidats
                et pilotez vos performances RH.
            </p>

            <div class="flex flex-col sm:flex-row justify-center gap-4">

                <a href="{{ path('app_application_new') }}"
                   class="bg-indigo-600 hover:bg-indigo-700 px-8 py-4 rounded-xl font-bold shadow-lg transition">
                    + Ajouter une candidature
                </a>

                <a href="{{ path('app_dashboard') }}"
                   class="border border-white px-8 py-4 rounded-xl font-bold hover:bg-white hover:text-indigo-900 transition">
                    Retour Dashboard
                </a>

            </div>

        </section>

    {% else %}
        <section class="bg-gradient-to-r from-slate-900 to-indigo-900 text-white rounded-3xl shadow-2xl p-12 text-center">

            <h2 class="text-4xl font-extrabold mb-5">
                Développez votre carrière
            </h2>

            <p class="text-slate-300 text-lg max-w-3xl mx-auto mb-8">
                Découvrez de nouvelles opportunités,
                postulez intelligemment
                et suivez votre progression professionnelle.
            </p>

            <div class="flex flex-col sm:flex-row justify-center gap-4">

                <a href="{{ path('app_job_offer_index') }}"
                   class="bg-indigo-600 hover:bg-indigo-700 px-8 py-4 rounded-xl font-bold shadow-lg transition">
                    Voir les offres
                </a>

                <a href="{{ path('app_dashboard') }}"
                   class="border border-white px-8 py-4 rounded-xl font-bold hover:bg-white hover:text-indigo-900 transition">
                    Retour Dashboard
                </a>

            </div>

        </section>
    {% endif %}

</div>

{% endblock %}