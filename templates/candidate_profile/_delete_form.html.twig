{% if is_granted('ROLE_ADMIN') or is_granted('ROLE_CANDIDATE') %}

<form method="post"
      action="{{ path('app_candidate_profile_delete', {'id': candidate_profile.id}) }}"
      onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer définitivement ce profil candidat ?');"
      class="inline-block">

    <input type="hidden"
           name="_token"
           value="{{ csrf_token('delete' ~ candidate_profile.id) }}">

    <button type="submit"
            class="bg-red-600 hover:bg-red-700 text-white px-8 py-4 rounded-xl shadow-lg font-bold transition duration-300 flex items-center gap-2">
        🗑️ Supprimer
    </button>

</form>

{% endif %}