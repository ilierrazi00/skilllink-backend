{{ form_start(form, {
    'attr': {
        'class': 'space-y-8'
    }
}) }}

<!-- TITRE PROFESSIONNEL -->
<div>
    {{ form_label(form.titreProfil, 'Titre professionnel', {
        'label_attr': {
            'class': 'block text-sm font-bold text-slate-700 mb-3'
        }
    }) }}

    {{ form_widget(form.titreProfil, {
        'attr': {
            'class': 'w-full bg-slate-50 border border-slate-300 rounded-xl px-5 py-4 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition shadow-sm'
        }
    }) }}

    {{ form_errors(form.titreProfil) }}
</div>

<!-- BIOGRAPHIE -->
<div>
    {{ form_label(form.bio, 'Biographie professionnelle', {
        'label_attr': {
            'class': 'block text-sm font-bold text-slate-700 mb-3'
        }
    }) }}

    {{ form_widget(form.bio, {
        'attr': {
            'class': 'w-full bg-slate-50 border border-slate-300 rounded-xl px-5 py-4 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition shadow-sm',
            'rows': 6,
            'placeholder': 'Décrivez votre parcours, vos spécialités, vos ambitions...'
        }
    }) }}

    {{ form_errors(form.bio) }}
</div>

<!-- EXPERIENCE + LOCALISATION -->
<div class="grid grid-cols-1 md:grid-cols-2 gap-8">

    <div>
        {{ form_label(form.experienceAnnees, 'Années d’expérience', {
            'label_attr': {
                'class': 'block text-sm font-bold text-slate-700 mb-3'
            }
        }) }}

        {{ form_widget(form.experienceAnnees, {
            'attr': {
                'class': 'w-full bg-slate-50 border border-slate-300 rounded-xl px-5 py-4 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition shadow-sm'
            }
        }) }}

        {{ form_errors(form.experienceAnnees) }}
    </div>

    <div>
        {{ form_label(form.localisation, 'Localisation', {
            'label_attr': {
                'class': 'block text-sm font-bold text-slate-700 mb-3'
            }
        }) }}

        {{ form_widget(form.localisation, {
            'attr': {
                'class': 'w-full bg-slate-50 border border-slate-300 rounded-xl px-5 py-4 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition shadow-sm',
                'placeholder': 'Ex : Paris, Lyon, Marseille...'
            }
        }) }}

        {{ form_errors(form.localisation) }}
    </div>

</div>

<!-- CV URL -->
<div>
    {{ form_label(form.cvUrl, 'Lien vers votre CV', {
        'label_attr': {
            'class': 'block text-sm font-bold text-slate-700 mb-3'
        }
    }) }}

    {{ form_widget(form.cvUrl, {
        'attr': {
            'class': 'w-full bg-slate-50 border border-slate-300 rounded-xl px-5 py-4 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition shadow-sm',
            'placeholder': 'https://mon-cv.com'
        }
    }) }}

    {{ form_errors(form.cvUrl) }}
</div>

<!-- DISPONIBILITE -->
<div class="bg-slate-50 rounded-2xl p-5 border border-slate-200">
    <div class="flex items-center space-x-4">

        {{ form_widget(form.disponibilite, {
            'attr': {
                'class': 'h-5 w-5 text-indigo-700 rounded focus:ring-indigo-500'
            }
        }) }}

        {{ form_label(form.disponibilite, 'Disponible immédiatement pour de nouvelles opportunités', {
            'label_attr': {
                'class': 'text-slate-700 font-semibold text-base'
            }
        }) }}

    </div>

    {{ form_errors(form.disponibilite) }}
</div>

<!-- USER -->
{% if is_granted('ROLE_ADMIN') %}
<div>
    {{ form_label(form.user, 'Utilisateur associé', {
        'label_attr': {
            'class': 'block text-sm font-bold text-slate-700 mb-3'
        }
    }) }}

    {{ form_widget(form.user, {
        'attr': {
            'class': 'w-full bg-slate-50 border border-slate-300 rounded-xl px-5 py-4 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition shadow-sm'
        }
    }) }}

    {{ form_errors(form.user) }}
</div>
{% else %}
    {% do form.user.setRendered %}
{% endif %}

<!-- SUBMIT -->
<div class="pt-8">
    <button class="w-full md:w-auto bg-gradient-to-r from-indigo-700 to-purple-700 hover:from-indigo-800 hover:to-purple-800 text-white font-bold px-10 py-4 rounded-xl shadow-xl transition duration-300 text-lg">
        🚀 {{ button_label|default('Enregistrer le profil') }}
    </button>
</div>

{{ form_end(form) }}