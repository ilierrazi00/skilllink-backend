{{ form_start(form, {
    'attr': {
        'class': 'space-y-8'
    }
}) }}

<!-- NOM -->
<div>
    {{ form_label(form.nom, 'Nom de la compétence', {
        'label_attr': {
            'class': 'block text-sm font-bold text-slate-700 mb-3'
        }
    }) }}

    {{ form_widget(form.nom, {
        'attr': {
            'class': 'w-full bg-slate-50 border border-slate-300 rounded-xl px-5 py-4 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition shadow-sm',
            'placeholder': 'Ex : Python, Symfony, Data Engineering...'
        }
    }) }}

    {{ form_errors(form.nom) }}
</div>

<!-- CATEGORIE -->
<div>
    {{ form_label(form.categorie, 'Catégorie', {
        'label_attr': {
            'class': 'block text-sm font-bold text-slate-700 mb-3'
        }
    }) }}

    {{ form_widget(form.categorie, {
        'attr': {
            'class': 'w-full bg-slate-50 border border-slate-300 rounded-xl px-5 py-4 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition shadow-sm',
            'placeholder': 'Ex : Développement, Cloud, Cybersécurité...'
        }
    }) }}

    {{ form_errors(form.categorie) }}
</div>

<!-- CANDIDATE PROFILES -->
{% if is_granted('ROLE_ADMIN') %}
<div>
    {{ form_label(form.candidateProfiles, 'Profils candidats associés', {
        'label_attr': {
            'class': 'block text-sm font-bold text-slate-700 mb-3'
        }
    }) }}

    <div class="bg-slate-50 border border-slate-300 rounded-2xl p-5 shadow-sm">
        {{ form_widget(form.candidateProfiles, {
            'attr': {
                'class': 'w-full bg-transparent outline-none'
            }
        }) }}
    </div>

    <p class="text-sm text-slate-500 mt-2">
        Sélectionnez les profils liés à cette compétence pour améliorer le matching global.
    </p>

    {{ form_errors(form.candidateProfiles) }}
</div>
{% else %}
    <div class="bg-indigo-50 border border-indigo-100 rounded-2xl p-6">
        <h3 class="text-lg font-bold text-indigo-700 mb-2">
            Association automatique
        </h3>

        <p class="text-slate-600">
            Les administrateurs peuvent gérer les associations globales entre compétences et profils.
            En tant que candidat, vous pouvez créer et enrichir votre compétence, mais la gestion avancée reste centralisée.
        </p>
    </div>
{% endif %}

<!-- SUBMIT -->
<div class="pt-8">
    <button class="w-full md:w-auto bg-gradient-to-r from-indigo-700 to-purple-700 hover:from-indigo-800 hover:to-purple-800 text-white font-bold px-10 py-4 rounded-xl shadow-xl transition duration-300 text-lg">
        🚀 {{ button_label|default('Enregistrer la compétence') }}
    </button>
</div>

{{ form_end(form) }}