{% extends 'base.html.twig' %}

{% block title %}Détail Entreprise | SkillLink{% endblock %}

{% block body %}

<div class="max-w-7xl mx-auto space-y-10">

    <!-- HERO -->
    <section class="bg-gradient-to-r from-indigo-700 to-purple-700 text-white rounded-3xl shadow-2xl p-10">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-8">

            <div>

                <span class="inline-block bg-white/20 backdrop-blur-sm px-4 py-2 rounded-full text-sm font-semibold uppercase tracking-wider mb-5">
                    {% if is_granted('ROLE_RECRUITER') or is_granted('ROLE_ADMIN') %}
                        Gestion entreprise
                    {% else %}
                        Découverte entreprise
                    {% endif %}
                </span>

                <h1 class="text-4xl md:text-5xl font-extrabold mb-4">
                    {{ company.nomEntreprise }} 🏢
                </h1>

                <p class="text-lg text-indigo-100 mb-4">
                    📍 {{ company.localisation ?: 'Localisation non renseignée' }}
                </p>

                <span class="inline-block bg-white/20 backdrop-blur-md px-5 py-2 rounded-full text-sm font-bold border border-white/30">
                    {{ company.secteur ?: 'Secteur non défini' }}
                </span>

            </div>

            <div class="text-7xl hidden md:block">
                🚀
            </div>

        </div>
    </section>

    <!-- STATS -->
    <section class="grid grid-cols-1 md:grid-cols-3 gap-8">

        <!-- Taille -->
        <div class="bg-white rounded-3xl shadow-lg p-8 border border-slate-100">
            <h2 class="text-slate-500 text-sm uppercase font-semibold mb-3">
                Taille de l’entreprise
            </h2>

            <p class="text-3xl font-extrabold text-indigo-700">
                {{ company.taille ?: 'Non définie' }}
            </p>
        </div>

        <!-- Site -->
        <div class="bg-white rounded-3xl shadow-lg p-8 border border-slate-100">
            <h2 class="text-slate-500 text-sm uppercase font-semibold mb-3">
                Site web
            </h2>

            {% if company.siteWeb %}
                <a href="{{ company.siteWeb }}"
                   target="_blank"
                   class="inline-block bg-indigo-100 hover:bg-indigo-200 text-indigo-700 font-bold px-5 py-3 rounded-xl transition">
                    Visiter le site
                </a>
            {% else %}
                <span class="text-slate-400 font-medium">
                    Non renseigné
                </span>
            {% endif %}
        </div>

        <!-- User -->
        <div class="bg-white rounded-3xl shadow-lg p-8 border border-slate-100">
            <h2 class="text-slate-500 text-sm uppercase font-semibold mb-3">
                {% if is_granted('ROLE_ADMIN') %}
                    Utilisateur associé
                {% else %}
                    Statut
                {% endif %}
            </h2>

            {% if is_granted('ROLE_ADMIN') %}
                <p class="text-lg font-bold text-purple-700 break-words">
                    {{ company.user ? company.user.email : 'Non associé' }}
                </p>
            {% else %}
                <p class="text-lg font-bold text-green-600">
                    Entreprise partenaire active
                </p>
            {% endif %}
        </div>

    </section>

    <!-- DESCRIPTION -->
    <section class="bg-white rounded-3xl shadow-2xl p-10 border border-slate-100">

        <h2 class="text-3xl font-bold text-slate-800 mb-6">
            Présentation de l’entreprise
        </h2>

        <div class="bg-slate-50 rounded-2xl p-8 text-slate-700 text-lg leading-relaxed border border-slate-200">
            {{ company.description ?: 'Aucune description renseignée.' }}
        </div>

    </section>

    <!-- ACTIONS -->
    <section class="bg-white rounded-3xl shadow-lg p-8 border border-slate-100">

        <div class="flex flex-col md:flex-row flex-wrap gap-4 justify-between items-center">

            <div class="flex flex-wrap gap-4">

                {% if is_granted('ROLE_RECRUITER') or is_granted('ROLE_ADMIN') %}
                    <a href="{{ path('app_company_edit', {'id': company.id}) }}"
                       class="bg-gradient-to-r from-indigo-700 to-purple-700 hover:from-indigo-800 hover:to-purple-800 text-white px-8 py-4 rounded-xl shadow-lg font-bold transition">
                        ✏️ Modifier
                    </a>
                {% endif %}

                <a href="{{ path('app_company_index') }}"
                   class="bg-slate-200 hover:bg-slate-300 text-slate-800 px-8 py-4 rounded-xl font-bold transition">
                    ← Retour
                </a>

            </div>

            <!-- DELETE -->
            {% if is_granted('ROLE_RECRUITER') or is_granted('ROLE_ADMIN') %}
                <div>
                    {{ include('company/_delete_form.html.twig') }}
                </div>
            {% endif %}

        </div>

    </section>

</div>

{% endblock %}