{% extends 'base.html.twig' %}

{% block title %}Nouvelle Entreprise | SkillLink{% endblock %}

{% block body %}

{% if is_granted('ROLE_RECRUITER') or is_granted('ROLE_ADMIN') %}

<div class="max-w-7xl mx-auto space-y-10">

    <!-- HERO -->
    <section class="bg-gradient-to-r from-indigo-700 to-purple-700 text-white rounded-3xl shadow-2xl p-10">
        <div class="flex flex-col md:flex-row justify-between items-center gap-8">

            <div>

                <span class="inline-block bg-white/20 backdrop-blur-sm px-4 py-2 rounded-full text-sm font-semibold uppercase tracking-wider mb-5">
                    Développement réseau B2B
                </span>

                <h1 class="text-4xl md:text-5xl font-extrabold mb-4">
                    Ajouter une Nouvelle Entreprise 🏢
                </h1>

                <p class="text-lg text-indigo-100 max-w-3xl">
                    Développez votre réseau de recruteurs,
                    partenaires et entreprises
                    en enrichissant l’écosystème SkillLink.
                </p>

            </div>

            <div class="text-7xl hidden md:block">
                🚀
            </div>

        </div>
    </section>

    <!-- FORM SECTION -->
    <section class="bg-white rounded-3xl shadow-2xl p-10 border border-slate-100">

        <div class="mb-10 text-center">

            <h2 class="text-3xl font-bold text-slate-800 mb-3">
                Création de l’entreprise
            </h2>

            <p class="text-slate-600 text-lg">
                Complétez les informations nécessaires
                pour intégrer une nouvelle entreprise.
            </p>

        </div>

        <!-- FORM -->
        <div class="space-y-8">
            {{ include('company/_form.html.twig') }}
        </div>

        <!-- RETURN -->
        <div class="mt-10 text-center">
            <a href="{{ path('app_company_index') }}"
               class="text-slate-600 hover:text-indigo-700 font-semibold transition text-lg">
                ← Retour à la liste
            </a>
        </div>

    </section>

</div>

{% else %}

<!-- ACCESS DENIED -->
<section class="max-w-4xl mx-auto bg-white rounded-3xl shadow-xl p-12 text-center border border-slate-100">

    <h1 class="text-4xl font-extrabold text-slate-800 mb-6">
        Accès non autorisé
    </h1>

    <p class="text-slate-600 text-lg mb-8">
        Cette fonctionnalité est réservée aux recruteurs et administrateurs.
    </p>

    <a href="{{ path('app_dashboard') }}"
       class="bg-indigo-700 hover:bg-indigo-800 text-white px-8 py-4 rounded-xl font-bold shadow-lg transition">
        Retour Dashboard
    </a>

</section>

{% endif %}

{% endblock %}