{{ form_start(form, {
    'attr': {
        'class': 'space-y-8'
    }
}) }}

<!-- NOM ENTREPRISE -->
<div>
    {{ form_label(form.nomEntreprise, 'Nom de l’entreprise', {
        'label_attr': {
            'class': 'block text-sm font-bold text-slate-700 mb-3'
        }
    }) }}

    {{ form_widget(form.nomEntreprise, {
        'attr': {
            'class': 'w-full bg-slate-50 border border-slate-300 rounded-xl px-5 py-4 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition shadow-sm',
            'placeholder': 'Ex : TechNova Solutions'
        }
    }) }}

    {{ form_errors(form.nomEntreprise) }}
</div>

<!-- DESCRIPTION -->
<div>
    {{ form_label(form.description, 'Description de l’entreprise', {
        'label_attr': {
            'class': 'block text-sm font-bold text-slate-700 mb-3'
        }
    }) }}

    {{ form_widget(form.description, {
        'attr': {
            'class': 'w-full bg-slate-50 border border-slate-300 rounded-xl px-5 py-4 min-h-[200px] focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition shadow-sm',
            'placeholder': 'Présentez votre entreprise, ses activités, sa mission...'
        }
    }) }}

    {{ form_errors(form.description) }}
</div>

<!-- SECTEUR + TAILLE -->
<div class="grid grid-cols-1 md:grid-cols-2 gap-8">

    <div>
        {{ form_label(form.secteur, 'Secteur d’activité', {
            'label_attr': {
                'class': 'block text-sm font-bold text-slate-700 mb-3'
            }
        }) }}

        {{ form_widget(form.secteur, {
            'attr': {
                'class': 'w-full bg-slate-50 border border-slate-300 rounded-xl px-5 py-4 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition shadow-sm',
                'placeholder': 'Ex : Technologie, Finance, Santé...'
            }
        }) }}

        {{ form_errors(form.secteur) }}
    </div>

    <div>
        {{ form_label(form.taille, 'Taille de l’entreprise', {
            'label_attr': {
                'class': 'block text-sm font-bold text-slate-700 mb-3'
            }
        }) }}

        {{ form_widget(form.taille, {
            'attr': {
                'class': 'w-full bg-slate-50 border border-slate-300 rounded-xl px-5 py-4 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition shadow-sm',
                'placeholder': 'Ex : PME, Startup, Grand Groupe...'
            }
        }) }}

        {{ form_errors(form.taille) }}
    </div>

</div>

<!-- LOCALISATION + SITE -->
<div class="grid grid-cols-1 md:grid-cols-2 gap-8">

    <div>
        {{ form_label(form.localisation, 'Localisation', {
            'label_attr': {
                'class': 'block text-sm font-bold text-slate-700 mb-3'
            }
        }) }}

        {{ form_widget(form.localisation, {
            'attr': {
                'class': 'w-full bg-slate-50 border border-slate-300 rounded-xl px-5 py-4 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition shadow-sm',
                'placeholder': 'Ex : Paris, France'
            }
        }) }}

        {{ form_errors(form.localisation) }}
    </div>

    <div>
        {{ form_label(form.siteWeb, 'Site web', {
            'label_attr': {
                'class': 'block text-sm font-bold text-slate-700 mb-3'
            }
        }) }}

        {{ form_widget(form.siteWeb, {
            'attr': {
                'class': 'w-full bg-slate-50 border border-slate-300 rounded-xl px-5 py-4 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition shadow-sm',
                'placeholder': 'https://www.monentreprise.com'
            }
        }) }}

        {{ form_errors(form.siteWeb) }}
    </div>

</div>

<!-- USER -->
{% if is_granted('ROLE_ADMIN') %}
<div>
    {{ form_label(form.user, 'Utilisateur associé', {
        'label_attr': {
            'class': 'block text-sm font-bold text-slate-700 mb-3'
        }
    }) }}

    {{ form_widget(form.user, {
        'attr': {
            'class': 'w-full bg-slate-50 border border-slate-300 rounded-xl px-5 py-4 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition shadow-sm'
        }
    }) }}

    {{ form_errors(form.user) }}
</div>
{% else %}
    {% do form.user.setRendered %}
{% endif %}

<!-- SUBMIT -->
<div class="pt-8">
    <button class="w-full md:w-auto bg-gradient-to-r from-indigo-700 to-purple-700 hover:from-indigo-800 hover:to-purple-800 text-white font-bold px-10 py-4 rounded-xl shadow-xl transition duration-300 text-lg">
        🚀 {{ button_label|default('Enregistrer l’entreprise') }}
    </button>
</div>

{{ form_end(form) }}