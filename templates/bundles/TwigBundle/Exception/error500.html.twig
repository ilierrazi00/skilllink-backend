{% extends 'base.html.twig' %}

{% block title %}Erreur serveur | SkillLink{% endblock %}

{% block body %}

<div class="max-w-6xl mx-auto py-20">

    <section class="bg-white rounded-3xl shadow-2xl overflow-hidden border border-slate-100">

        <div class="grid grid-cols-1 lg:grid-cols-2">

            <!-- LEFT -->
            <div class="bg-gradient-to-br from-slate-900 via-indigo-900 to-purple-900 text-white p-14 flex flex-col justify-center relative">

                <div class="relative z-10">

                    <span class="inline-block bg-white/20 backdrop-blur-sm px-4 py-2 rounded-full text-sm font-semibold uppercase tracking-wider mb-6">
                        Erreur 500
                    </span>

                    <h1 class="text-6xl md:text-7xl font-extrabold mb-8">
                        Incident serveur
                    </h1>

                    <p class="text-xl text-indigo-100 leading-relaxed mb-8">
                        Une erreur interne
                        est survenue sur SkillLink.
                        Nos équipes techniques
                        travaillent à rétablir la situation.
                    </p>

                    <div class="space-y-4">

                        <div class="flex items-center gap-3">
                            <span class="text-2xl">⚙️</span>
                            <span>Maintenance technique</span>
                        </div>

                        <div class="flex items-center gap-3">
                            <span class="text-2xl">🛡️</span>
                            <span>Système sécurisé</span>
                        </div>

                        <div class="flex items-center gap-3">
                            <span class="text-2xl">🚀</span>
                            <span>Rétablissement en cours</span>
                        </div>

                    </div>

                </div>

                <div class="absolute bottom-0 right-0 text-[220px] opacity-10 font-black leading-none select-none hidden lg:block">
                    500
                </div>

            </div>

            <!-- RIGHT -->
            <div class="p-14 flex flex-col justify-center text-center">

                <div class="text-8xl mb-8">
                    🧠
                </div>

                <h2 class="text-4xl font-extrabold text-slate-800 mb-6">
                    Oups...
                </h2>

                <p class="text-slate-600 text-lg leading-relaxed mb-10">
                    Une anomalie technique
                    empêche momentanément
                    l’accès à cette fonctionnalité.
                </p>

                <div class="flex flex-col sm:flex-row gap-4 justify-center">

                    <a href="{{ path('app_home') }}"
                       class="bg-gradient-to-r from-indigo-700 to-purple-700 hover:from-indigo-800 hover:to-purple-800 text-white px-8 py-4 rounded-xl font-bold shadow-lg transition">
                        🏠 Retour accueil
                    </a>

                    <a href="{{ path('app_dashboard') }}"
                       class="bg-slate-200 hover:bg-slate-300 text-slate-800 px-8 py-4 rounded-xl font-bold transition">
                        📊 Dashboard
                    </a>

                </div>

                <p class="mt-8 text-xs text-slate-400">
                    Symfony • Docker • Monitoring • SkillLink
                </p>

            </div>

        </div>

    </section>

</div>

{% endblock %}