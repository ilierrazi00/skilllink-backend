{% extends 'base.html.twig' %}

{% block title %}Connexion | SkillLink{% endblock %}

{% block body %}

<div class="max-w-7xl mx-auto py-16">

    <div class="grid grid-cols-1 lg:grid-cols-2 bg-white rounded-3xl shadow-2xl overflow-hidden border border-slate-100">

        <!-- ===================================================== -->
        <!-- LEFT PANEL -->
        <!-- ===================================================== -->
        <div class="bg-gradient-to-br from-indigo-700 via-purple-700 to-indigo-900 text-white p-12 md:p-16 flex flex-col justify-center relative">

            <div class="relative z-10">

                <span class="inline-block bg-white/20 backdrop-blur-sm px-4 py-2 rounded-full text-sm font-semibold uppercase tracking-wider mb-6">
                    Espace sécurisé • Authentification
                </span>

                <h1 class="text-5xl md:text-6xl font-extrabold leading-tight mb-8">
                    Bon retour sur
                    <span class="text-indigo-200">SkillLink 🚀</span>
                </h1>

                <p class="text-xl text-indigo-100 leading-relaxed mb-12">
                    Connectez-vous à votre espace professionnel,
                    gérez vos opportunités,
                    vos recrutements
                    et développez votre réseau RH.
                </p>

                <!-- Features -->
                <div class="space-y-6">

                    <div class="flex items-center gap-4">
                        <span class="text-3xl">🎯</span>
                        <span class="text-lg font-medium">
                            Matching intelligent
                        </span>
                    </div>

                    <div class="flex items-center gap-4">
                        <span class="text-3xl">📊</span>
                        <span class="text-lg font-medium">
                            Dashboard RH complet
                        </span>
                    </div>

                    <div class="flex items-center gap-4">
                        <span class="text-3xl">🔐</span>
                        <span class="text-lg font-medium">
                            Sécurité JWT + RBAC
                        </span>
                    </div>

                    <div class="flex items-center gap-4">
                        <span class="text-3xl">🏢</span>
                        <span class="text-lg font-medium">
                            Recruteurs & candidats connectés
                        </span>
                    </div>

                </div>

                <!-- Extra trust block -->
                <div class="mt-12 bg-white/10 backdrop-blur-md rounded-2xl p-6 border border-white/20">
                    <h3 class="font-bold text-xl mb-3">
                        Pourquoi SkillLink ?
                    </h3>

                    <ul class="space-y-2 text-indigo-100 text-sm">
                        <li>✔ Gestion centralisée des candidatures</li>
                        <li>✔ Analyse avancée des profils</li>
                        <li>✔ Expérience utilisateur moderne</li>
                        <li>✔ Plateforme évolutive Symfony/API</li>
                    </ul>
                </div>

            </div>

            <!-- Decorative -->
            <div class="absolute bottom-0 right-0 text-[200px] opacity-10 font-black leading-none select-none hidden lg:block">
                Link
            </div>

        </div>

        <!-- ===================================================== -->
        <!-- RIGHT PANEL -->
        <!-- ===================================================== -->
        <div class="p-10 md:p-14 flex flex-col justify-center">

            <!-- Header -->
            <div class="text-center mb-10">
                <h2 class="text-4xl font-extrabold text-indigo-700 mb-3">
                    Connexion
                </h2>

                <p class="text-slate-600 text-lg">
                    Accédez à votre espace SkillLink
                </p>
            </div>

            <!-- Already logged -->
            {% if app.user %}
                <div class="mb-6 p-4 rounded-2xl bg-green-100 text-green-700 border border-green-300 font-medium shadow-sm">
                    Vous êtes connecté en tant que {{ app.user.userIdentifier }},
                    <a href="{{ path('app_logout') }}" class="font-bold underline ml-2">
                        Déconnexion
                    </a>
                </div>
            {% endif %}

            <!-- ERROR -->
            {% if error %}
                <div class="mb-6 p-4 rounded-2xl bg-red-100 text-red-700 border border-red-300 font-medium shadow-sm">
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            <!-- FORM -->
            <form method="post"
                  action="{{ path('app_login') }}"
                  class="space-y-7">

                <!-- EMAIL -->
                <div>
                    <label for="username"
                           class="block text-sm font-bold text-slate-700 mb-3">
                        Adresse email
                    </label>

                    <input type="email"
                           value="{{ last_username }}"
                           name="_username"
                           id="username"
                           class="w-full rounded-xl border border-slate-300 bg-slate-50 px-5 py-4 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition shadow-sm"
                           autocomplete="email"
                           placeholder="Votre email"
                           required
                           autofocus>
                </div>

                <!-- PASSWORD -->
                <div>
                    <label for="password"
                           class="block text-sm font-bold text-slate-700 mb-3">
                        Mot de passe
                    </label>

                    <input type="password"
                           name="_password"
                           id="password"
                           class="w-full rounded-xl border border-slate-300 bg-slate-50 px-5 py-4 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition shadow-sm"
                           autocomplete="current-password"
                           placeholder="Votre mot de passe"
                           required>
                </div>

                <!-- CSRF -->
                <input type="hidden"
                       name="_csrf_token"
                       value="{{ csrf_token('authenticate') }}">

                <!-- Remember + Forgot -->
                <div class="flex flex-col md:flex-row md:justify-between md:items-center gap-4 bg-slate-50 rounded-2xl p-4 border border-slate-200">

                    <div class="flex items-center gap-3">
                        <input type="checkbox"
                               name="_remember_me"
                               id="_remember_me"
                               class="h-5 w-5 text-indigo-600 rounded">

                        <label for="_remember_me"
                               class="text-sm font-medium text-slate-700">
                            Se souvenir de moi
                        </label>
                    </div>

                    <!-- IMPORTANT RESET PASSWORD LINK -->
                    <a href="{{ path('app_forgot_password_request') }}"
                       class="text-sm text-indigo-700 font-semibold hover:underline transition">
                        Mot de passe oublié ?
                    </a>

                </div>

                <!-- Submit -->
                <button class="w-full bg-gradient-to-r from-indigo-700 to-purple-700 hover:from-indigo-800 hover:to-purple-800 text-white font-bold py-4 rounded-xl shadow-xl transition duration-300 text-lg hover:scale-[1.02]"
                        type="submit">
                    🔐 Se connecter
                </button>

            </form>

            <!-- Divider -->
            <div class="flex items-center my-8">
                <div class="flex-grow border-t border-slate-200"></div>
                <span class="px-4 text-sm text-slate-400 font-medium">ou</span>
                <div class="flex-grow border-t border-slate-200"></div>
            </div>

            <!-- Register CTA -->
            <div class="text-center text-slate-600">
                Pas encore inscrit ?
                <a href="{{ path('app_register') }}"
                   class="text-indigo-700 font-bold hover:underline ml-2">
                    Créer un compte
                </a>
            </div>

            <!-- Quick recruiter/candidate links -->
            <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-4">

                <div class="bg-slate-50 rounded-2xl p-4 border border-slate-100 text-center">
                    <div class="text-2xl mb-2">👤</div>
                    <h3 class="font-bold text-slate-800">Candidat</h3>
                    <p class="text-sm text-slate-500">
                        Gérez vos candidatures
                    </p>
                </div>

                <div class="bg-slate-50 rounded-2xl p-4 border border-slate-100 text-center">
                    <div class="text-2xl mb-2">🏢</div>
                    <h3 class="font-bold text-slate-800">Recruteur</h3>
                    <p class="text-sm text-slate-500">
                        Pilotez vos recrutements
                    </p>
                </div>

            </div>

            <!-- Security Notice -->
            <div class="mt-8 text-center text-xs text-slate-400 leading-relaxed">
                Votre connexion est protégée par
                chiffrement sécurisé, gestion avancée des rôles,
                conformité CDA et bonnes pratiques DevSecOps.
            </div>

        </div>

    </div>

</div>

{% endblock %}