<form method="post"
      action="{{ path('app_job_offer_delete', {'id': job_offer.id}) }}"
      onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer définitivement cette offre d’emploi ? Cette action est irréversible.');"
      class="inline-block">

    <input type="hidden"
           name="_token"
           value="{{ csrf_token('delete' ~ job_offer.id) }}">

    <button type="submit"
            class="bg-red-600 hover:bg-red-700 text-white px-8 py-4 rounded-xl shadow-lg font-bold transition duration-300 flex items-center gap-2">
        🗑️ Supprimer l’offre
    </button>

</form>