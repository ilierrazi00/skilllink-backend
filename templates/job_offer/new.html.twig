{% extends 'base.html.twig' %}

{% block title %}Nouvelle Offre | SkillLink{% endblock %}

{% block body %}

<div class="max-w-7xl mx-auto space-y-10">

    <!-- HERO -->
    <section class="bg-gradient-to-r from-indigo-700 to-purple-700 text-white rounded-3xl shadow-2xl p-10">
        <div class="flex flex-col md:flex-row justify-between items-center gap-8">

            <div>
                <span class="inline-block bg-white/20 backdrop-blur-sm px-4 py-2 rounded-full text-sm font-semibold uppercase tracking-wider mb-5">
                    Recrutement • Publication stratégique
                </span>

                <h1 class="text-4xl md:text-5xl font-extrabold mb-4">
                    Publier une Nouvelle Offre d’Emploi 💼
                </h1>

                <p class="text-lg text-indigo-100 max-w-3xl">
                    Créez une opportunité professionnelle attractive,
                    recrutez efficacement,
                    améliorez votre sourcing
                    et développez votre présence sur SkillLink.
                </p>
            </div>

            <div class="text-7xl hidden md:block">
                🚀
            </div>

        </div>
    </section>

    <!-- KPI INFO -->
    <section class="grid grid-cols-1 md:grid-cols-3 gap-6">

        <div class="bg-white rounded-2xl shadow-lg p-6 border border-slate-100">
            <h2 class="text-slate-500 text-sm uppercase font-semibold mb-2">
                Visibilité
            </h2>

            <p class="text-3xl font-bold text-indigo-700">
                Nationale
            </p>
        </div>

        <div class="bg-white rounded-2xl shadow-lg p-6 border border-slate-100">
            <h2 class="text-slate-500 text-sm uppercase font-semibold mb-2">
                Matching IA
            </h2>

            <p class="text-3xl font-bold text-pink-600">
                Activé
            </p>
        </div>

        <div class="bg-white rounded-2xl shadow-lg p-6 border border-slate-100">
            <h2 class="text-slate-500 text-sm uppercase font-semibold mb-2">
                Recrutement
            </h2>

            <p class="text-3xl font-bold text-green-600">
                Optimisé
            </p>
        </div>

    </section>

    <!-- FORM SECTION -->
    <section class="bg-white rounded-3xl shadow-2xl p-10 border border-slate-100">

        <div class="mb-10 text-center">
            <h2 class="text-3xl font-bold text-slate-800 mb-3">
                Informations de l’offre
            </h2>

            <p class="text-slate-600 text-lg">
                Complétez soigneusement les informations nécessaires
                pour publier votre offre de manière professionnelle,
                maximiser son attractivité
                et améliorer la qualité du recrutement.
            </p>
        </div>

        <!-- FORM -->
        <div class="space-y-8">
            {{ include('job_offer/_form.html.twig') }}
        </div>

        <!-- RETURN -->
        <div class="mt-10 text-center">
            <a href="{{ path('app_job_offer_index') }}"
               class="text-slate-600 hover:text-indigo-700 font-semibold transition text-lg">
                ← Retour à la liste
            </a>
        </div>

    </section>

    <!-- RECRUITER TIPS -->
    <section class="bg-gradient-to-r from-slate-900 to-indigo-900 text-white rounded-3xl shadow-2xl p-10">

        <h2 class="text-3xl font-extrabold mb-6 text-center">
            Conseils pour une offre performante
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

            <div class="bg-white/10 rounded-2xl p-6 backdrop-blur-sm">
                <h3 class="font-bold text-xl mb-3">
                    🎯 Titre précis
                </h3>

                <p class="text-slate-200">
                    Utilisez un intitulé clair,
                    attractif
                    et aligné avec le marché.
                </p>
            </div>

            <div class="bg-white/10 rounded-2xl p-6 backdrop-blur-sm">
                <h3 class="font-bold text-xl mb-3">
                    🛠️ Compétences ciblées
                </h3>

                <p class="text-slate-200">
                    Sélectionnez les compétences essentielles
                    pour renforcer le matching intelligent.
                </p>
            </div>

            <div class="bg-white/10 rounded-2xl p-6 backdrop-blur-sm">
                <h3 class="font-bold text-xl mb-3">
                    📈 Description complète
                </h3>

                <p class="text-slate-200">
                    Décrivez clairement missions,
                    avantages
                    et contexte du poste.
                </p>
            </div>

        </div>

    </section>

</div>

{% endblock %}