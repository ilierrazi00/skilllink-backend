{% extends 'base.html.twig' %}

{% block title %}Détail Offre | SkillLink{% endblock %}

{% block body %}

{% set currentUser = app.user %}
{% set roleType = currentUser ? currentUser.roleType : null %}

<div class="max-w-7xl mx-auto space-y-10">

    <!-- HERO -->
    <section class="bg-gradient-to-r from-indigo-700 to-purple-700 text-white rounded-3xl shadow-2xl p-10">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-8">

            <div>
                <h1 class="text-4xl md:text-5xl font-extrabold mb-4">
                    {{ job_offer.titre }} 💼
                </h1>

                <p class="text-lg text-indigo-100 mb-4">
                    🏢 {{ job_offer.company.nomEntreprise }} — 📍 {{ job_offer.localisation ?: 'Localisation non renseignée' }}
                </p>

                <div class="flex flex-wrap gap-3">

                    <span class="inline-block bg-white/20 backdrop-blur-md px-5 py-2 rounded-full text-sm font-bold border border-white/30">
                        {{ job_offer.typeContrat }}
                    </span>

                    {% if job_offer.remotePossible %}
                        <span class="inline-block bg-green-500/20 text-green-100 px-5 py-2 rounded-full text-sm font-bold border border-green-300/30">
                            Télétravail possible
                        </span>
                    {% else %}
                        <span class="inline-block bg-red-500/20 text-red-100 px-5 py-2 rounded-full text-sm font-bold border border-red-300/30">
                            Présentiel
                        </span>
                    {% endif %}

                </div>
            </div>

            <div class="text-7xl hidden md:block">
                🚀
            </div>

        </div>
    </section>

    <!-- STATS -->
    <section class="grid grid-cols-1 md:grid-cols-4 gap-8">

        <!-- Salaire -->
        <div class="bg-white rounded-3xl shadow-lg p-8 border border-slate-100">
            <h2 class="text-slate-500 text-sm uppercase font-semibold mb-3">
                Salaire
            </h2>

            <p class="text-3xl font-extrabold text-indigo-700">
                {{ job_offer.salaire ? job_offer.salaire ~ ' €' : 'À négocier' }}
            </p>
        </div>

        <!-- Télétravail -->
        <div class="bg-white rounded-3xl shadow-lg p-8 border border-slate-100">
            <h2 class="text-slate-500 text-sm uppercase font-semibold mb-3">
                Télétravail
            </h2>

            <p class="text-3xl font-extrabold">
                {% if job_offer.remotePossible %}
                    <span class="text-green-600">Oui</span>
                {% else %}
                    <span class="text-red-600">Non</span>
                {% endif %}
            </p>
        </div>

        <!-- Publication -->
        <div class="bg-white rounded-3xl shadow-lg p-8 border border-slate-100">
            <h2 class="text-slate-500 text-sm uppercase font-semibold mb-3">
                Date de publication
            </h2>

            <p class="text-xl font-bold text-purple-700">
                {{ job_offer.datePublication ? job_offer.datePublication|date('d/m/Y') : 'Non disponible' }}
            </p>
        </div>

        <!-- Entreprise -->
        <div class="bg-white rounded-3xl shadow-lg p-8 border border-slate-100">
            <h2 class="text-slate-500 text-sm uppercase font-semibold mb-3">
                Secteur
            </h2>

            <p class="text-xl font-bold text-green-600">
                {{ job_offer.company.secteur ?: 'Non défini' }}
            </p>
        </div>

    </section>

    <!-- DESCRIPTION -->
    <section class="bg-white rounded-3xl shadow-2xl p-10 border border-slate-100">

        <h2 class="text-3xl font-bold text-slate-800 mb-6">
            Description du poste
        </h2>

        <div class="bg-slate-50 rounded-2xl p-8 text-slate-700 text-lg leading-relaxed border border-slate-200 whitespace-pre-line">
            {{ job_offer.description ?: 'Aucune description renseignée.' }}
        </div>

    </section>

    <!-- ENTREPRISE -->
    <section class="bg-white rounded-3xl shadow-2xl p-10 border border-slate-100">

        <h2 class="text-3xl font-bold text-slate-800 mb-6">
            Présentation de l’entreprise
        </h2>

        <div class="space-y-4">

            <p class="text-lg text-slate-700 leading-relaxed">
                {{ job_offer.company.description ?: 'Aucune présentation disponible.' }}
            </p>

            <div class="flex flex-wrap gap-4 pt-4">

                <a href="{{ path('app_company_show', {'id': job_offer.company.id}) }}"
                   class="bg-indigo-100 hover:bg-indigo-200 text-indigo-700 px-6 py-3 rounded-xl font-bold transition">
                    Voir l’entreprise
                </a>

                {% if job_offer.company.siteWeb %}
                    <a href="{{ job_offer.company.siteWeb }}"
                       target="_blank"
                       class="bg-purple-100 hover:bg-purple-200 text-purple-700 px-6 py-3 rounded-xl font-bold transition">
                        Site officiel
                    </a>
                {% endif %}

            </div>

        </div>

    </section>

    <!-- SKILLS -->
    <section class="bg-white rounded-3xl shadow-2xl p-10 border border-slate-100">

        <h2 class="text-3xl font-bold text-slate-800 mb-8">
            Compétences requises
        </h2>

        {% if job_offer.skills|length > 0 %}

            <div class="flex flex-wrap gap-4">

                {% for skill in job_offer.skills %}
                    <span class="bg-indigo-100 text-indigo-700 px-5 py-3 rounded-full font-bold shadow-sm">
                        {{ skill.nom }}
                    </span>
                {% endfor %}

            </div>

        {% else %}

            <div class="bg-slate-50 rounded-2xl p-8 text-center border border-slate-200">
                <p class="text-slate-500 text-lg">
                    Aucune compétence spécifiée pour cette offre.
                </p>
            </div>

        {% endif %}

    </section>

    <!-- CTA CANDIDAT -->
    {% if roleType == 'candidate' %}
        <section class="bg-gradient-to-r from-green-600 to-emerald-700 text-white rounded-3xl shadow-2xl p-10 text-center">

            <h2 class="text-4xl font-extrabold mb-5">
                Cette offre vous intéresse ?
            </h2>

            <p class="text-green-100 text-lg max-w-3xl mx-auto mb-8">
                Candidatez directement via SkillLink
                et profitez du matching intelligent
                pour optimiser vos chances.
            </p>

            <a href="{{ path('app_application_new') }}"
               class="bg-white text-green-700 hover:bg-green-50 px-10 py-4 rounded-xl font-bold shadow-lg transition">
                🚀 Postuler maintenant
            </a>

        </section>
    {% endif %}

    <!-- ACTIONS -->
    <section class="bg-white rounded-3xl shadow-lg p-8 border border-slate-100">

        <div class="flex flex-col md:flex-row flex-wrap gap-4 justify-between items-center">

            <div class="flex flex-wrap gap-4">

                {% if roleType == 'recruiter' or roleType == 'admin' %}
                    <a href="{{ path('app_job_offer_edit', {'id': job_offer.id}) }}"
                       class="bg-gradient-to-r from-indigo-700 to-purple-700 hover:from-indigo-800 hover:to-purple-800 text-white px-8 py-4 rounded-xl shadow-lg font-bold transition">
                        ✏️ Modifier
                    </a>
                {% endif %}

                <a href="{{ path('app_job_offer_index') }}"
                   class="bg-slate-200 hover:bg-slate-300 text-slate-800 px-8 py-4 rounded-xl font-bold transition">
                    ← Retour
                </a>

            </div>

            {% if roleType == 'recruiter' or roleType == 'admin' %}
                <div>
                    {{ include('job_offer/_delete_form.html.twig') }}
                </div>
            {% endif %}

        </div>

    </section>

</div>

{% endblock %}