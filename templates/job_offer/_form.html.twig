{{ form_start(form, {
    'attr': {
        'class': 'space-y-8'
    }
}) }}

<!-- TITRE -->
<div>
    {{ form_label(form.titre, 'Titre du poste', {
        'label_attr': {
            'class': 'block text-sm font-bold text-slate-700 mb-3'
        }
    }) }}

    {{ form_widget(form.titre, {
        'attr': {
            'class': 'w-full bg-slate-50 border border-slate-300 rounded-xl px-5 py-4 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition shadow-sm',
            'placeholder': 'Ex : Data Engineer Senior'
        }
    }) }}

    <p class="text-sm text-slate-500 mt-2">
        Choisissez un titre clair, précis et attractif pour maximiser la visibilité.
    </p>

    {{ form_errors(form.titre) }}
</div>

<!-- DESCRIPTION -->
<div>
    {{ form_label(form.description, 'Description du poste', {
        'label_attr': {
            'class': 'block text-sm font-bold text-slate-700 mb-3'
        }
    }) }}

    {{ form_widget(form.description, {
        'attr': {
            'class': 'w-full bg-slate-50 border border-slate-300 rounded-xl px-5 py-4 min-h-[220px] focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition shadow-sm',
            'placeholder': 'Décrivez les missions, responsabilités, objectifs, avantages et environnement du poste...'
        }
    }) }}

    <p class="text-sm text-slate-500 mt-2">
        Une description détaillée améliore l’attractivité et le matching.
    </p>

    {{ form_errors(form.description) }}
</div>

<!-- CONTRAT + SALAIRE -->
<div class="grid grid-cols-1 md:grid-cols-2 gap-8">

    <div>
        {{ form_label(form.typeContrat, 'Type de contrat', {
            'label_attr': {
                'class': 'block text-sm font-bold text-slate-700 mb-3'
            }
        }) }}

        {{ form_widget(form.typeContrat, {
            'attr': {
                'class': 'w-full bg-slate-50 border border-slate-300 rounded-xl px-5 py-4 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition shadow-sm'
            }
        }) }}

        {{ form_errors(form.typeContrat) }}
    </div>

    <div>
        {{ form_label(form.salaire, 'Salaire annuel (€)', {
            'label_attr': {
                'class': 'block text-sm font-bold text-slate-700 mb-3'
            }
        }) }}

        {{ form_widget(form.salaire, {
            'attr': {
                'class': 'w-full bg-slate-50 border border-slate-300 rounded-xl px-5 py-4 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition shadow-sm',
                'placeholder': 'Ex : 45000'
            }
        }) }}

        <p class="text-sm text-slate-500 mt-2">
            Une transparence salariale renforce la qualité des candidatures.
        </p>

        {{ form_errors(form.salaire) }}
    </div>

</div>

<!-- LOCALISATION + REMOTE -->
<div class="grid grid-cols-1 md:grid-cols-2 gap-8">

    <div>
        {{ form_label(form.localisation, 'Localisation', {
            'label_attr': {
                'class': 'block text-sm font-bold text-slate-700 mb-3'
            }
        }) }}

        {{ form_widget(form.localisation, {
            'attr': {
                'class': 'w-full bg-slate-50 border border-slate-300 rounded-xl px-5 py-4 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition shadow-sm',
                'placeholder': 'Ex : Paris, Lyon, Télétravail...'
            }
        }) }}

        {{ form_errors(form.localisation) }}
    </div>

    <div class="bg-slate-50 rounded-2xl p-6 border border-slate-200 flex items-center mt-8 md:mt-0">
        <div class="flex items-center space-x-4">

            {{ form_widget(form.remotePossible, {
                'attr': {
                    'class': 'h-5 w-5 text-indigo-700 rounded focus:ring-indigo-500'
                }
            }) }}

            {{ form_label(form.remotePossible, 'Télétravail possible', {
                'label_attr': {
                    'class': 'text-slate-700 font-semibold text-base'
                }
            }) }}

        </div>

        {{ form_errors(form.remotePossible) }}
    </div>

</div>

<!-- DATE -->
<div>
    {{ form_label(form.datePublication, 'Date de publication', {
        'label_attr': {
            'class': 'block text-sm font-bold text-slate-700 mb-3'
        }
    }) }}

    {{ form_widget(form.datePublication, {
        'attr': {
            'class': 'w-full bg-slate-50 border border-slate-300 rounded-xl px-5 py-4 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition shadow-sm'
        }
    }) }}

    {{ form_errors(form.datePublication) }}
</div>

<!-- COMPANY -->
<div>
    {{ form_label(form.company, 'Entreprise', {
        'label_attr': {
            'class': 'block text-sm font-bold text-slate-700 mb-3'
        }
    }) }}

    {{ form_widget(form.company, {
        'attr': {
            'class': 'w-full bg-slate-50 border border-slate-300 rounded-xl px-5 py-4 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition shadow-sm'
        }
    }) }}

    <p class="text-sm text-slate-500 mt-2">
        Vérifiez que l’offre est correctement liée à votre structure.
    </p>

    {{ form_errors(form.company) }}
</div>

<!-- SKILLS -->
<div>
    {{ form_label(form.skills, 'Compétences requises', {
        'label_attr': {
            'class': 'block text-sm font-bold text-slate-700 mb-3'
        }
    }) }}

    <div class="bg-slate-50 border border-slate-300 rounded-2xl p-5 shadow-sm">
        {{ form_widget(form.skills, {
            'attr': {
                'class': 'w-full bg-transparent outline-none'
            }
        }) }}
    </div>

    <p class="text-sm text-slate-500 mt-2">
        Sélectionnez les compétences essentielles pour améliorer la pertinence du matching IA.
    </p>

    {{ form_errors(form.skills) }}
</div>

<!-- SUBMIT -->
<div class="pt-8">
    <button class="w-full md:w-auto bg-gradient-to-r from-indigo-700 to-purple-700 hover:from-indigo-800 hover:to-purple-800 text-white font-bold px-10 py-4 rounded-xl shadow-xl transition duration-300 text-lg">
        🚀 {{ button_label|default('Enregistrer l’offre') }}
    </button>
</div>

{{ form_end(form) }}