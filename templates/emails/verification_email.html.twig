<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Vérification Email | SkillLink</title>
</head>
<body style="margin:0; padding:0; background-color:#f1f5f9; font-family:Arial, sans-serif;">

    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="background-color:#f1f5f9; padding:40px 0;">
        <tr>
            <td align="center">

                <!-- MAIN CONTAINER -->
                <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0"
                       style="max-width:700px; background:#ffffff; border-radius:24px; overflow:hidden; box-shadow:0 10px 30px rgba(0,0,0,0.08);">

                    <!-- HEADER -->
                    <tr>
                        <td style="background:linear-gradient(135deg,#4338ca,#7c3aed,#312e81); padding:50px; text-align:center; color:white;">
                            <h1 style="margin:0; font-size:42px; font-weight:800;">
                                Bienvenue sur SkillLink 🚀
                            </h1>

                            <p style="margin-top:20px; font-size:18px; color:#e0e7ff; line-height:1.6;">
                                Confirmez votre adresse email
                                pour sécuriser votre compte
                                et accéder à votre plateforme RH intelligente.
                            </p>
                        </td>
                    </tr>

                    <!-- BODY -->
                    <tr>
                        <td style="padding:50px; color:#334155;">

                            <h2 style="font-size:28px; margin-bottom:20px; color:#4338ca;">
                                Vérification de votre compte
                            </h2>

                            <p style="font-size:17px; line-height:1.8; margin-bottom:30px;">
                                Merci de rejoindre SkillLink.<br><br>

                                Cliquez sur le bouton ci-dessous
                                pour activer votre compte
                                et finaliser votre inscription sécurisée.
                            </p>

                            <!-- CTA BUTTON -->
                            <table role="presentation" cellspacing="0" cellpadding="0" border="0" align="center" style="margin:40px auto;">
                                <tr>
                                    <td align="center" bgcolor="#4338ca" style="border-radius:14px;">
                                        <a href="{{ signedUrl|raw }}"
                                           style="display:inline-block; padding:18px 40px; font-size:18px; font-weight:bold; color:white; text-decoration:none; border-radius:14px;">
                                            ✅ Vérifier mon email
                                        </a>
                                    </td>
                                </tr>
                            </table>

                            <p style="font-size:15px; color:#64748b; text-align:center; margin-top:20px;">
                                Ce lien expirera dans :
                                <strong>{{ expiresAtMessageKey|trans(expiresAtMessageData, 'VerifyEmailBundle') }}</strong>
                            </p>

                            <!-- SECURITY INFO -->
                            <div style="margin-top:50px; padding:25px; background:#f8fafc; border:1px solid #e2e8f0; border-radius:18px;">
                                <h3 style="margin-top:0; color:#4338ca;">
                                    🔐 Sécurité SkillLink
                                </h3>

                                <p style="margin:0; font-size:15px; line-height:1.7; color:#475569;">
                                    Votre compte bénéficie
                                    d’une sécurité avancée :
                                    chiffrement,
                                    conformité RGPD,
                                    contrôle des accès
                                    et bonnes pratiques DevSecOps.
                                </p>
                            </div>

                        </td>
                    </tr>

                    <!-- FOOTER -->
                    <tr>
                        <td style="background:#0f172a; color:#cbd5e1; text-align:center; padding:35px; font-size:13px;">

                            <p style="margin:0 0 10px 0;">
                                © {{ "now"|date("Y") }} SkillLink — Plateforme intelligente de recrutement
                            </p>

                            <p style="margin:0;">
                                Symfony • API Platform • JWT • Docker • Tailwind
                            </p>

                        </td>
                    </tr>

                </table>

            </td>
        </tr>
    </table>

</body>
</html>